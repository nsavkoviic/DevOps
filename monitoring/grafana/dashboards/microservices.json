{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate (per service)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count[5m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "HTTP Request Duration P95 (per service)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) by (job)",
          "legendFormat": "{{job}} — 5xx"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Active HTTP Connections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "http_server_active_requests by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "Process Memory (MB)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "process_runtime_dotnet_gc_heap_size_bytes / 1024 / 1024",
          "legendFormat": "{{job}} — Heap"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["devops", "microservices"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DevOps Microservices Dashboard",
  "uid": "devops-microservices",
  "version": 1
}
